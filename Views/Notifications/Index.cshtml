@model IEnumerable<GROUP9PoetryWebsite.Models.Notification>

<div class="container mt-5">
    <h2 class="mb-4">🔔 Your Notifications</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You have no new notifications at this time.
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var notification in Model)
            {
                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    <div>
                        <strong class="text-primary">@@@notification.Username</strong>
                        <p class="mb-1 d-inline-block ms-2">@notification.Message</p>
                    </div>
                    
                    @if (!notification.IsRead)
                    {
                        <span class="badge bg-danger rounded-pill">New</span>
                    }
                </div>
            }
        </div>
    }
</div>