@model IEnumerable<GROUP9PoetryWebsite.Models.Poem>
@{
    ViewData["Title"] = "Menu";
}

@section Styles {
    <link rel="stylesheet" href="~/css/menuindex.css" asp-append-version="true" />
}

<!-- NAV -->
<nav class="ph-nav">
    <a class="ph-logo" href="#">Poetry <em>Haven</em></a>
    <div class="ph-nav-divider"></div>
    <div class="ph-search">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <path d="M21 21l-4.35-4.35" />
        </svg>
        <input type="text" id="poemSearch" oninput="filterPoems()" placeholder="Search poems, poets…" />
    </div>
    <div class="ph-spacer"></div>
    <button class="ph-nav-action" onclick="toggleNotif()" aria-label="Notifications">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
        </svg>
        <span class="ph-badge" id="notifBadge">3</span>
    </button>
    <div class="ph-avatar" id="profileAvatar" onclick="toggleProfile()" title="My Profile">
        @(User.Identity.IsAuthenticated? User.Identity.Name.Substring(0, 1).ToUpper() : "G")
    </div>
</nav>

<!-- PROFILE DROPDOWN -->
<div id="profileDrop" class="ph-profile-drop">
    @if (User.Identity.IsAuthenticated)
    {
        <div class="ph-profile-head">
            <div class="ph-profile-avatar-lg">@User.Identity.Name.Substring(0, 1).ToUpper()</div>
            <div>
                <p class="ph-profile-name">@User.Identity.Name</p>
                <p class="ph-profile-email">@(User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "No email on file")</p>
            </div>
        </div>
        <div class="ph-drop-divider"></div>
        <a asp-controller="Account" asp-action="ChangePassword" class="ph-drop-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            Change Password
        </a>
        <div class="ph-drop-divider"></div>
        <form asp-controller="Menu" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="ph-drop-logout">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Log Out
            </button>
        </form>
    }
    else
    {
        <p class="ph-profile-guest">You are browsing as a guest.</p>
        <a asp-controller="Account" asp-action="Login" class="ph-drop-link">Log In</a>
    }
</div>

<!-- TOAST -->
@if (TempData["PublishSuccess"] != null)
{
    <div class="ph-toast ph-toast-success" id="toastBanner">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6L9 17l-5-5" /></svg>
        @TempData["PublishSuccess"]
    </div>
}
@if (TempData["PublishError"] != null)
{
    <div class="ph-toast ph-toast-error" id="toastBanner">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
        </svg>
        @TempData["PublishError"]
    </div>
}

<!-- MAIN PAGE -->
<div class="ph-page">
    <!-- ALWAYS 2-COLUMN GRID — sidebar never moves -->
    <div class="ph-grid">
        <main class="ph-main">
            <!-- Feed title + tabs inside main so sidebar column is never affected -->
            <div class="ph-feed-header">
                <h2 class="ph-feed-title">The <em>Feed</em></h2>
                <div class="ph-tabs" id="mainTabs">
                    <button class="ph-tab active" onclick="setTab(this,'all')">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                        For You
                    </button>
                    <button class="ph-tab" onclick="setTab(this,'following')">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                        </svg>
                        Following
                    </button>
                    <button class="ph-tab" onclick="setTab(this,'new')">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="16" />
                            <line x1="8" y1="12" x2="16" y2="12" />
                        </svg>
                        New
                    </button>
                </div>
            </div>

            <div class="ph-feed" id="feedList">
                @foreach (var p in Model)
                {
                    <article class="ph-poem-card"
                             data-title="@p.Title.ToLower()"
                             data-author="@(p.Author?.ToLower() ?? "")"
                             data-tags=""
                             data-tab="all">

                        <span class="ph-card-badge">#@p.Id</span>

                        <div class="ph-author-row">
                            <div class="ph-author-avt">
                                @(string.IsNullOrEmpty(p.Author) ? "U" : p.Author.Substring(0, 1).ToUpper())
                            </div>

                            <div class="ph-author-name">@(p.Author ?? "Anonymous")</div>

                            <button class="ph-author-follow"
                                    data-author="@(p.Author ?? "Anonymous")"
                                    onclick="toggleFollow(this, '@(p.Author ?? "Anonymous")')">
                                Follow
                            </button>
                        </div>

                        <h3 class="ph-poem-title">@p.Title</h3>
                        <div class="ph-poem-excerpt">@p.Text</div>

                        <div class="ph-card-foot">
                            @{
                                bool isLiked = ((HashSet<int>)ViewBag.LikedPoemIds).Contains(p.Id);
                            }
                            <button class="ph-like-btn @(isLiked ? "liked" : "")"
                                    onclick="toggleLikeServer(this, '@p.Id')">
                                <svg viewBox="0 0 24 24" width="13" height="13">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                                          stroke="@(isLiked ? "#c0392b" : "currentColor")"
                                          fill="@(isLiked ? "#c0392b" : "none")"
                                          stroke-width="1.8" />
                                </svg>
                                <span class="like-count">@p.LikesCount</span>
                            </button>

                            <button class="ph-bookmark-btn" onclick="toggleSave(this)">
                                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
                                </svg>
                                Save
                            </button>
                            @if (p.Anthology.Id != 1) // 1 is the default number for poems not belonging to an anthology
                            {
                                <hr style="border-left: 1px solid var(--ph-accent); height: 25px">
                                <button class="ph-bookmark-btn">Anthology: <i>@p.Anthology.Title</i></button>
                            }
                            <a href="javascript:void(0)"
                               class="ph-read-more"
                               onclick="openReadModal('@p.Title', '@System.Web.HttpUtility.JavaScriptStringEncode(p.Text)', '@p.Author', '@p.Anthology.Title')">
                                Read full ↗
                            </a>
                        </div>
                    </article>
                }
            </div>

            <div id="noResults" class="no-results">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="11" cy="11" r="8" />
                    <path d="M21 21l-4.35-4.35" />
                    <line x1="8" y1="11" x2="14" y2="11" />
                </svg>
                No poems or poets found matching your search.
            </div>
        </main>

        <!-- SIDEBAR — outside <main>, always stays in right column -->
        <aside class="ph-sidebar">

            <!-- Verse of the Day -->
            <div class="ph-sb-block">
                <p class="ph-sb-title">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z" />
                        <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z" />
                    </svg>
                    Verse of the day
                </p>
                <div class="ph-quote">
                    <div class="ph-quote-text" id="qotdText"></div>
                    <div class="ph-quote-attr" id="qotdAttr"></div>
                </div>
            </div>

            <!-- Trending Tags -->
            <div class="ph-sb-block">
                <p class="ph-sb-title">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
                        <polyline points="16 7 22 7 22 13" />
                    </svg>
                    Trending tags
                </p>
                <div class="ph-tags">
                    <span class="ph-tag" onclick="filterByTag(this,'loss')">#loss</span>
                    <span class="ph-tag" onclick="filterByTag(this,'nature')">#nature</span>
                    <span class="ph-tag" onclick="filterByTag(this,'love')">#love</span>
                    <span class="ph-tag" onclick="filterByTag(this,'solitude')">#solitude</span>
                    <span class="ph-tag" onclick="filterByTag(this,'seasons')">#seasons</span>
                    <span class="ph-tag" onclick="filterByTag(this,'memory')">#memory</span>
                    <span class="ph-tag" onclick="filterByTag(this,'hope')">#hope</span>
                    <span class="ph-tag" onclick="filterByTag(this,'midnight')">#midnight</span>
                    <span class="ph-tag" onclick="filterByTag(this,'ocean')">#ocean</span>
                    <span class="ph-tag" onclick="filterByTag(this,'silence')">#silence</span>
                </div>
            </div>

            <!-- Poets to Follow -->
            <div class="ph-sb-block">
                <p class="ph-sb-title">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                    Poets to follow
                </p>
                <div class="ph-writer-row">
                    <div class="ph-writer-avt av-teal">M</div>
                    <div><div class="ph-writer-name">Marisol Vega</div><div class="ph-writer-meta">34 poems · Lyric</div></div>
                    <button class="ph-follow-btn"
                            data-author="Marisol Vega"
                            onclick="toggleFollow(this,'Marisol Vega')">
                        Follow
                    </button>
                </div>
                <div class="ph-writer-row">
                    <div class="ph-writer-avt av-rose">J</div>
                    <div><div class="ph-writer-name">James Okafor</div><div class="ph-writer-meta">21 poems · Elegy</div></div>
                    <button class="ph-follow-btn"
                            data-author="James Okafor"
                            onclick="toggleFollow(this,'James Okafor')">
                        Follow
                    </button>
                </div>
                <div class="ph-writer-row">
                    <div class="ph-writer-avt av-slate">L</div>
                    <div><div class="ph-writer-name">Lena Hoang</div><div class="ph-writer-meta">58 poems · Haiku</div></div>
                    <button class="ph-follow-btn"
                            data-author="Lena Hoang"
                            onclick="toggleFollow(this,'Lena Hoang')">
                        Follow
                    </button>
                </div>
                <div class="ph-writer-row">
                    <div class="ph-writer-avt av-peach">D</div>
                    <div><div class="ph-writer-name">Diego Ferreira</div><div class="ph-writer-meta">17 poems · Narrative</div></div>
                    <button class="ph-follow-btn"
                            data-author="Diego Ferreira"
                            onclick="toggleFollow(this,'Diego Ferreira')">
                        Follow
                    </button>
                </div>
            </div>

        </aside>
    </div>
</div>

<!-- FIXED FAB — always visible bottom-right -->
<button class="ph-fab" onclick="openUpload()" title="Write a Poem" aria-label="Write a Poem">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19" />
        <line x1="5" y1="12" x2="19" y2="12" />
    </svg>
    <span class="ph-fab-label">Write a Poem</span>
</button>

<!-- NOTIFICATIONS PANEL -->
<div class="ph-notif-overlay" id="notifOverlay">
    <div class="ph-notif-scrim" onclick="closeNotif()"></div>
    <div class="ph-notif-panel">
        <div class="ph-notif-head">
            <span>Notifications</span>
            <button class="ph-notif-clear" onclick="clearNotifs()">Mark all read</button>
        </div>
        <div class="ph-notif-list" id="notifList"></div>
    </div>
</div>

<!-- UPLOAD MODAL -->
<div class="ph-modal-wrap" id="uploadModal" onclick="closeModalOutside(event,'uploadModal',closeUpload)">
    <form asp-controller="Menu" asp-action="Create" method="post" class="ph-modal">
        @Html.AntiForgeryToken()
        <div class="ph-modal-head">
            <h3>Share a <em>Verse</em></h3>
            <button type="button" class="ph-modal-close" onclick="closeUpload()">✕</button>
        </div>
        <div class="ph-form-group">
            <label>Title</label>
            <input type="text" name="Title" placeholder="Give your poem a title…" required />
        </div>
        <div class="ph-form-group">
            <label>Your Verse</label>
            <textarea name="Text" placeholder="Write your poem here…" required></textarea>
        </div>
        <div class="ph-modal-foot">
            <button type="button" class="ph-btn-cancel" onclick="closeUpload()">Cancel</button>
            <button type="submit" class="ph-btn-publish">Publish</button>
        </div>
    </form>
</div>

<!-- READ POEM MODAL -->
<div class="ph-modal-wrap" id="readModal" onclick="closeModalOutside(event,'readModal',closeReadModal)">
    <div class="ph-modal ph-read-modal">
        <div class="ph-modal-head">
            <div></div>
            <button type="button" class="ph-modal-close" onclick="closeReadModal()">✕</button>
        </div>
        <h2 class="ph-read-title" id="readModalTitle">—</h2>
        <p class="ph-read-author">by <span id="readModalAuthor">—</span></p>
        <div class="ph-read-text" id="readModalText"></div>
        <div class="ph-modal-foot" style="margin-top:1.5rem;">
            <button id="readModalAnthologyTitle" class="ph-btn-cancel"></button>
        </div>
    </div>
</div>


<script>
    // Toast auto-dismiss
    const toast = document.getElementById('toastBanner');
    if (toast) setTimeout(() => toast.remove(), 4000);

    @if (TempData["PublishError"] != null)
    {
            <text>openUpload();</text>
    }

    // ── Verse of the Day ──────────────────────────────────────────────────
    const QUOTES = [
        { text: '"Two roads diverged in a wood, and I — I took the one less traveled by."', attr: '— Robert Frost' },
        { text: '"Hold fast to dreams, for if dreams die, life is a broken-winged bird."', attr: '— Langston Hughes' },
        { text: '"Still I rise, like dust, I\'ll rise."', attr: '— Maya Angelou' },
        { text: '"Once upon a midnight dreary, while I pondered, weak and weary…"', attr: '— Edgar Allan Poe' },
        { text: '"The woods are lovely, dark and deep, but I have promises to keep."', attr: '— Robert Frost' },
    ];
    const q = QUOTES[Math.floor(Math.random() * QUOTES.length)];
    document.getElementById('qotdText').textContent = q.text;
    document.getElementById('qotdAttr').textContent = q.attr;

    // ── Notifications ─────────────────────────────────────────────────────
    const NOTIFICATIONS = [
        { type:'like',       unread:true,  av:'av-teal',  initial:'M', actor:'Marisol Vega',   poem:'"Ashes at Dawn"', time:'2 minutes ago'  },
        { type:'like',       unread:true,  av:'av-slate', initial:'L', actor:'Lena Hoang',     poem:'"Still Water"',   time:'15 minutes ago' },
        { type:'follow',     unread:true,  av:'av-rose',  initial:'J', actor:'James Okafor',   poem:null,              time:'1 hour ago'     },
        { type:'followback', unread:false, av:'av-peach', initial:'D', actor:'Diego Ferreira', poem:null,              time:'Yesterday'      },
        { type:'like',       unread:false, av:'av-sage',  initial:'R', actor:'Riya Mehta',     poem:'"Tidal"',         time:'2 days ago'     },
    ];

    function notifMessage(n) {
        if (n.type === 'like')       return `<strong>${n.actor}</strong> liked your poem <strong>${n.poem}</strong>`;
        if (n.type === 'follow')     return `<strong>${n.actor}</strong> started following you`;
        if (n.type === 'followback') return `<strong>${n.actor}</strong> followed you back`;
        return '';
    }

    function renderNotifs() {
        document.getElementById('notifList').innerHTML = NOTIFICATIONS.map(n => `
            <div class="ph-notif-item ${n.unread ? 'unread' : ''}">
                <div class="ph-notif-dot ${n.unread ? '' : 'read'}"></div>
                <div class="ph-notif-avt ${n.av}">${n.initial}</div>
                <div>
                    <div class="ph-notif-text">${notifMessage(n)}</div>
                    <div class="ph-notif-time">${n.time}</div>
                </div>
            </div>`).join('');
    }
    renderNotifs();



    function updateBadge() {
        const count = NOTIFICATIONS.filter(n => n.unread).length;
        const badge = document.getElementById('notifBadge');
        badge.textContent = count > 0 ? count : '';
        badge.style.display = count > 0 ? 'inline-flex' : 'none';
    }
    updateBadge();

    function addNotif(notif) { NOTIFICATIONS.unshift(notif); renderNotifs(); updateBadge(); }
    function toggleNotif()   { document.getElementById('notifOverlay').classList.toggle('open'); }
    function closeNotif()    { document.getElementById('notifOverlay').classList.remove('open'); }
    function clearNotifs()   { NOTIFICATIONS.forEach(n => n.unread = false); renderNotifs(); updateBadge(); }

    // ── Profile dropdown ──────────────────────────────────────────────────
    function toggleProfile() {
        const d = document.getElementById('profileDrop');
        const a = document.getElementById('profileAvatar');
        const open = d.classList.toggle('open');
        a.classList.toggle('active', open);
    }
    document.addEventListener('click', function(e) {
        const d = document.getElementById('profileDrop');
        const a = document.getElementById('profileAvatar');
        if (!d.contains(e.target) && !a.contains(e.target)) {
            d.classList.remove('open');
            a.classList.remove('active');
        }
    });

    // ── Tabs ──────────────────────────────────────────────────────────────
    let currentTab = 'all';
    let currentTag = null;
    let followedAuthors = [];

    function setTab(el, tab) {
        currentTab = tab;

        document.querySelectorAll('.ph-tab').forEach(t =>
            t.classList.remove('active')
        );
        el.classList.add('active');

        applyFilters();
    }

    // ── Tag filtering ─────────────────────────────────────────────────────
    function filterByTag(el, tag) {
        if (currentTag === tag) {
            currentTag = null;
            el.classList.remove('active');
        } else {
            currentTag = tag;
            document.querySelectorAll('.ph-tag').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }
        applyFilters();
    }

    // ── Combined filter (tab + tag + search) ──────────────────────────────
    function applyFilters() {
        const searchVal = (document.getElementById('poemSearch').value || '').toLowerCase();
        const cards = document.querySelectorAll('.ph-poem-card');
        const feed = document.getElementById('feedList');
        const noResults = document.getElementById('noResults');

        let visible = 0;

        cards.forEach(card => {
            const cardAuthor = (card.dataset.author || '').trim().toLowerCase();
            const cardTitle = card.dataset.title || '';

            let tabMatch = true;

            // For You = all
            if (currentTab === 'all') {
                tabMatch = true;
            }

            // Following = only followed authors
            else if (currentTab === 'following') {
                tabMatch = followedAuthors.includes(cardAuthor);
            }

            // New = show nothing
            else if (currentTab === 'new') {
                tabMatch = false;
            }

            const searchMatch =
                searchVal === '' ||
                cardTitle.includes(searchVal) ||
                cardAuthor.includes(searchVal);

            const show = tabMatch && searchMatch;

            card.style.display = show ? '' : 'none';

            if (show) visible++;
        });

        if (visible === 0) {
            feed.style.display = 'none';
            noResults.style.display = 'flex';

            if (currentTab === 'new') {
                noResults.innerHTML = `
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 8v4"/>
                        <path d="M12 16h.01"/>
                    </svg>
                    No new poems yet ✨
                `;
            }
            else if (currentTab === 'following') {
                noResults.innerHTML = `
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M8 12h8"/>
                    </svg>
                    Follow poets to see their poems 💛
                `;
            }
            else {
                noResults.innerHTML = `
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="M21 21l-4.35-4.35"/>
                    </svg>
                    No poems or poets found matching your search.
                `;
            }
        } else {
            feed.style.display = 'flex';
            noResults.style.display = 'none';
        }
    }

    // ── Save / Bookmark ───────────────────────────────────────────────────
    function toggleSave(btn) {
        const svg  = btn.querySelector('svg');
        const isSaved = btn.classList.toggle('saved');
        svg.setAttribute('fill', isSaved ? 'currentColor' : 'none');
        btn.innerHTML = btn.innerHTML.replace(isSaved ? 'Save' : 'Saved', isSaved ? 'Saved' : 'Save');
    }

    // ── Modals ────────────────────────────────────────────────────────────
    function openUpload()  { document.getElementById('uploadModal').classList.add('open'); }
    function closeUpload() { document.getElementById('uploadModal').classList.remove('open'); }

    function openReadModal(title, text, author, anthologyTitle) {
        document.getElementById('readModalTitle').textContent  = title;
        document.getElementById('readModalAuthor').textContent = author;
        document.getElementById('readModalText').textContent   = text;
        document.getElementById('readModalAnthologyTitle').textContent   = anthologyTitle;
        document.getElementById('readModal').classList.add('open');
    }
    function closeReadModal() { document.getElementById('readModal').classList.remove('open'); }

    function closeModalOutside(e, id, fn) { if (e.target.id === id) fn(); }

    // ── Like (server) ─────────────────────────────────────────────────────
    async function toggleLikeServer(btn, poemId) {
        const token   = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const path    = btn.querySelector('path');
        const countEl = btn.querySelector('.like-count');
        const response = await fetch(`/Menu/ToggleLike?poemId=${poemId}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': token }
        });
        if (response.ok) {
            const result = await response.json();
            countEl.textContent = result.newCount;
            btn.classList.toggle('liked', result.liked);
            path.setAttribute('fill',   result.liked ? '#c0392b' : 'none');
            path.setAttribute('stroke', result.liked ? '#c0392b' : 'currentColor');
        }
        }function toggleFollow(btn, authorName) {
        const author = authorName.trim().toLowerCase();

        const alreadyFollowing = followedAuthors.includes(author);
        const isFollowing = !alreadyFollowing;

        if (isFollowing) {
            followedAuthors.push(author);
        } else {
            followedAuthors = followedAuthors.filter(a => a !== author);
        }

        // sync ALL buttons
        document.querySelectorAll('.ph-author-follow, .ph-follow-btn').forEach(followBtn => {
            const btnAuthor = followBtn.getAttribute('data-author');

            if (btnAuthor && btnAuthor.trim().toLowerCase() === author) {
                followBtn.classList.toggle('following', isFollowing);
                followBtn.textContent = isFollowing ? 'Following' : 'Follow';
            }
        });

        applyFilters();
    }
</script>

